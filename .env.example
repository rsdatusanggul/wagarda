PORT=10000

# Security Configuration for Defaults (Required)
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASS=wagw-admin-secret123
DEFAULT_API_KEY=wagw-secret-key123

# CORS Configuration (Comma separated list of allowed domains)
# Gunakan * untuk mengizinkan semua (tidak disarankan untuk produksi)
# Pisahkan dengan koma jika ada banyak domain
ALLOWED_ORIGINS=https://docs.google.com,https://your-hospital-domain.com
